    "installer": {
        "args": "--do-not-launch-chrome"
    },
    "checkver": {
        "url": "https://api.github.com/repos/Hibbiki/chromium-win64/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v(?<version>[\\d.]+)(?<subver>\\-r\\w+)",
        "replace": "${version}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Hibbiki/chromium-win64/releases/download/v$version$matchSubver/mini_installer.exe",
                "hash": {
                    "url": "https://github.com/Hibbiki/chromium-win64/releases/latest",
                    "regex": "$sha1 \\.\\./out/x64/mini_installer.exe"
                }
            }
        }
    }
