            "hash": "sha1:43173c3cfd18e9007cb367c7404a3d69dc70c4d9"
        },
        "32bit": {
            "url": "https://sourceforge.net/projects/tigervnc/files/stable/1.16.2/vncviewer-1.16.2.exe#/vncviewer.exe",
