{
    "version": "6.0.0-beta01",
    "description": "One-stop online barrage drama tracking platform",
    "homepage": "https://github.com/open-ani/animeko",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/open-ani/animeko/releases/download/v6.0.0-beta01/ani-6.0.0-beta01-windows-x86_64.zip",
            "hash": "f8aee4d479d6a98edc7a330cb358c79677a02b3dfd22732661cfda135fd94703",
            "extract_dir": "Ani"
        }
    },
    "bin": "Ani.exe",
    "shortcuts": [
        [
            "Ani.exe",
            "Ani"
        ]
    ],
    "persist_external": [
        [
            "$env:APPDATA\\Him188",
            "data",
            "directory"
        ],
        [
            "$env:LOCALAPPDATA\\Him188",
            "cache",
            "directory"
        ]
    ],
    "post_install": [
        ". \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/persist-external.ps1\"",
        "Invoke-PersistExternalInstall -Manifest $manifest -PersistDir $persist_dir -Dir $dir"
    ],
    "pre_uninstall": [
        ". \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/persist-external.ps1\"",
        "Invoke-PersistExternalUninstall -Manifest $manifest -Dir $dir"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/open-ani/animeko/releases?per_page=10",
        "jsonpath": "$.[?(@.prerelease==true)].tag_name",
        "regex": "v([\\d.]+[-\\w]*)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/open-ani/animeko/releases/download/v$version/ani-$version-windows-x86_64.zip"
            }
        }
    }
}
